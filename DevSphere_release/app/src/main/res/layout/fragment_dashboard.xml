<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ds_bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hey, Developer 👋"
                    android:textColor="@color/ds_text_primary" android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/tvRole"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Role: Free" android:textColor="@color/ds_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
            <TextView android:id="@+id/tvRoleBadge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FREE" android:padding="8dp"
                android:background="@drawable/badge_user"
                android:textColor="@color/ds_bg_dark" android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Upgrade CTA -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/upgradeCtaCard"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/ds_bg_card"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/ds_accent_gold"
            app:strokeWidth="1dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🚀 Unlock Full DevSphere"
                    android:textColor="@color/ds_accent_gold" android:textSize="15sp"
                    android:textStyle="bold" android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Get DevTools, server manager, code editor, HLS downloader and more."
                    android:textColor="@color/ds_text_secondary" android:textSize="13sp"
                    android:layout_marginBottom="12dp" />
                <Button android:id="@+id/btnUpgrade"
                    android:layout_width="wrap_content" android:layout_height="40dp"
                    android:text="Upgrade Now" android:backgroundTint="@color/ds_accent_gold"
                    android:textColor="@color/ds_bg_dark" android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Launch Cards -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Quick Launch" android:textColor="@color/ds_text_primary"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvModules"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" android:nestedScrollingEnabled="false" />

        <!-- Active Servers -->
        <LinearLayout android:id="@+id/serversSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚡ Active Servers"
                android:textColor="@color/ds_text_primary" android:textSize="15sp"
                android:textStyle="bold" android:layout_marginBottom="8dp" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="56dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardBackgroundColor="@color/ds_bg_card" app:cardCornerRadius="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="  🟢 Node API :3000 — Running"
                    android:textColor="@color/ds_text_primary" android:textSize="14sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Recent Downloads -->
        <LinearLayout android:id="@+id/downloadsSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📥 Recent Downloads"
                android:textColor="@color/ds_text_primary" android:textSize="15sp"
                android:textStyle="bold" android:layout_marginBottom="8dp" />
        </LinearLayout>

        <!-- Activity Feed -->
        <LinearLayout android:id="@+id/activitySection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊 Activity Feed"
                android:textColor="@color/ds_text_primary" android:textSize="15sp"
                android:textStyle="bold" android:layout_marginBottom="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
