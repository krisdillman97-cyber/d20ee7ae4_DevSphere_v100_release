<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ds_bg_dark">

    <!-- Toolbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:background="@color/ds_bg_surface"
        android:padding="4dp" android:gravity="center_vertical">

        <Spinner android:id="@+id/spinnerLanguage"
            android:layout_width="120dp" android:layout_height="36dp"
            android:backgroundTint="@color/ds_bg_card"
            android:popupBackground="@color/ds_bg_card" />
        <TextView android:id="@+id/tvLanguage"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" />

        <ImageButton android:id="@+id/btnRun"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@android:drawable/ic_media_play"
            android:backgroundTint="@android:color/transparent"
            android:tint="@color/ds_accent_green" />
        <ImageButton android:id="@+id/btnSave"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_save"
            android:backgroundTint="@android:color/transparent"
            android:tint="@color/ds_accent_blue" />
        <ImageButton android:id="@+id/btnCopy"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_share"
            android:backgroundTint="@android:color/transparent"
            android:tint="@color/ds_text_secondary" />
    </LinearLayout>

    <!-- Code Editor Area -->
    <EditText android:id="@+id/codeEditor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="@color/ds_bg_dark"
        android:padding="12dp"
        android:textColor="@color/ds_accent_green"
        android:textSize="13sp"
        android:gravity="top|start"
        android:inputType="textMultiLine|textNoSuggestions"
        android:scrollbars="vertical"
        android:fontFamily="monospace" />

    <!-- Output Panel -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/ds_border" />
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <TextView android:id="@+id/tvOutput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="12dp" android:textColor="@color/ds_text_secondary"
            android:textSize="12sp" android:fontFamily="monospace"
            android:text="> Output will appear here" />
    </ScrollView>

    <!-- Upgrade overlay -->
    <FrameLayout android:id="@+id/upgradeOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#CC0D0D0F" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🔒 Developer plan required\nUpgrade to access Code Editor"
            android:textColor="@color/ds_text_primary" android:gravity="center"
            android:textSize="16sp" />
    </FrameLayout>
</LinearLayout>
